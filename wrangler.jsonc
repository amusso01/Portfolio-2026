{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "portfolio-2026",
	"compatibility_date": "2026-03-08",
	"main": "src/worker.ts",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS",
		"not_found_handling": "single-page-application",
		"run_worker_first": ["/api/*"],
	},
	"observability": {
		"enabled": true,
	},
}
